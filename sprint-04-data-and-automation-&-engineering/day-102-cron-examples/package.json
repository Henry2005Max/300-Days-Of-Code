{
  "name": "day-102-cron-examples",
  "version": "1.0.0",
  "description": "Day 102 - Multi-job Cron Scheduler with node-cron and job history",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
